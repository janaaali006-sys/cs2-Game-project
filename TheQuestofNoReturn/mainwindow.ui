       </rect>
      </property>
      <property name="styleSheet">
       <string notr="true">QPushButton {

    background-color: qradialgradient(
        cx:0.5, cy:0.5,
        radius:1.2,
        fx:0.5, fy:0.5,
        stop:0 #ffcc66,
        stop:0.4 #d97706,
        stop:1 #5a2d0c
    );

    color: #2b1200;

    border: none;

    border-radius: 45px;

    font-size: 20px;

    font-weight: bold;

    font-family: &quot;Copperplate&quot;;

    padding: 18px;

    

    /* subtle inner glow feeling */

    min-width: 220px;

    min-height: 70px;

}



QPushButton:hover {

    background-color: qradialgradient(
        cx:0.5, cy:0.5,
        radius:1.3,
        fx:0.5, fy:0.5,
        stop:0 #ffe29a,
        stop:0.4 #f59e0b,
        stop:1 #7c2d12
    );

}



QPushButton:pressed {

    background-color: #4a1f00;

    color: #ffdd99;

}</string>
